		Sprite(...);
		_owner = owner;
		hasImage = true;
		setSize(GetSideMenuScaledWidth(), WINDOW_HEIGHT);
		fillRect(0, 0, GetSideMenuScaledWidth(), WINDOW_HEIGHT, 0);
		setAffineOffset(0, 0);
		zoom = 100;
		setPos(0, 0);
		hitThreshold = 0;
		visible = true;
	}
	function onButtonDownL(target){
