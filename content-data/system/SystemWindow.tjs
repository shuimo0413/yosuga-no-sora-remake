var ROLE_NAME_IMAGE_DEFAULT = "nothing.png";

function GetRoleNameImage(roleName){
	var file = ROLE_NAME_IMAGE_DEFAULT;
	for(var i=0; i<ROLE_NAME_IMAGES.count; i++){
		if(ROLE_NAME_IMAGES[i][0] == roleName){
			file = ROLE_NAME_IMAGES[i][1];
			break;
		}
	}
	return RoleNameUiFile(file);
}
function ResolveHistoryRoleImageFile(roleName){
	var file = GetRoleNameImage(roleName);
	if(Storages.isExistentStorage(file)) return file;
	file = RoleNameUiFile("nothing.png");
	if(Storages.isExistentStorage(file)) return file;
	return "";
}

function GetSideMenuScale(){
	return (WINDOW_HEIGHT * 100) \ SIDE_MENU_BASE_HEIGHT;
}
function GetSideMenuScaledWidth(){
	return (SIDE_MENU_BASE_WIDTH * GetSideMenuScale()) \ 100;
}
function ScaleSideMenuValue(v){
	return (int(v) * GetSideMenuScale()) \ 100;
}
function HistoryUiFile(file){
	return HISTORY_UI_PATH + file;
}
function RoleNameUiFile(file){
	return ROLE_NAME_PATH + file;
}
function GetHistoryUIScale(){
	return (WINDOW_HEIGHT * 100) \ HISTORY_UI_BASE_HEIGHT;
}
function ScaleHistoryUIValue(v){
	return (int(v) * GetHistoryUIScale()) \ 100;
}
function ScaleHistoryUILayerImage(obj){
	if(GetHistoryUIScale() == 100) return;
	if(obj.imageWidth <= 0 || obj.imageHeight <= 0) return;

	var src = new global.Layer(obj.window, obj.parent);
	src.assignImages(obj);

	var iw = obj.imageWidth;
	var ih = obj.imageHeight;
	var w = obj.width;
	var h = obj.height;
	var sw = ScaleHistoryUIValue(iw);
	var sh = ScaleHistoryUIValue(ih);

	obj.setImageSize(sw, sh);
	obj.setSize(ScaleHistoryUIValue(w), ScaleHistoryUIValue(h));
	obj.stretchCopy(0, 0, sw, sh, src, 0, 0, iw, ih, stFastLinear);

	invalidate src;
}
function LoadHistoryUIScaledLayer(win, par, file){
	var img = new global.Layer(win, par);
	img.loadImages(HistoryUiFile(file));
	img.setSizeToImageSize();
	ScaleHistoryUILayerImage(img);
	return img;
}
function LoadSaveUiFile(file){
	return LOADSAVE_UI_PATH + file;
}
function GetLoadSaveScale(){
	return (WINDOW_HEIGHT * 100) \ LOADSAVE_BASE_HEIGHT;
}
function GetLoadSaveScaledWidth(){
	return (LOADSAVE_BASE_WIDTH * GetLoadSaveScale()) \ 100;
}
function ScaleLoadSaveValue(v){
	return (int(v) * GetLoadSaveScale()) \ 100;
}
function SetupSideMenuWindow(obj, color=void){
	obj.zoom = 100;
	obj.setPos(0, 0);
	obj.setSize(WINDOW_WIDTH, WINDOW_HEIGHT);
	obj.fillRect(0, 0, obj.width, obj.height, 0);
	if(color !== void)
		obj.fillRect(0, 0, GetSideMenuScaledWidth(), WINDOW_HEIGHT, color);
}
function SetupLoadSaveWindow(obj, color=void){
	obj.zoom = 100;
	obj.setPos(0, 0);
	obj.setSize(WINDOW_WIDTH, WINDOW_HEIGHT);
	obj.fillRect(0, 0, obj.width, obj.height, 0);
	if(color !== void)
		obj.fillRect(0, 0, obj.width, obj.height, color);
}
