	obj.stretchCopy(0, 0, sw, sh, src, 0, 0, iw, ih, stFastLinear);

	invalidate src;
}
function LoadSideMenuScaledLayer(win, par, file){
	var img = new global.Layer(win, par);
	img.loadImages(file);
	img.setSizeToImageSize();
	ScaleSideMenuLayerImage(img);
	return img;
}
function LoadLoadSaveScaledLayer(win, par, file){
	var img = new global.Layer(win, par);
	img.loadImages(file);
	img.setSizeToImageSize();
	ScaleLoadSaveLayerImage(img);
	return img;
}
class SideMenuRoot extends Sprite{
