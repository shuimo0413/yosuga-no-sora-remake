	if(GetSideMenuScale() == 100) return;
	if(obj.imageWidth <= 0 || obj.imageHeight <= 0) return;

	var src = new global.Layer(obj.window, obj.parent);
	src.assignImages(obj);

	var iw = obj.imageWidth;
	var ih = obj.imageHeight;
	var w = obj.width;
	var h = obj.height;
	var sw = ScaleSideMenuValue(iw);
