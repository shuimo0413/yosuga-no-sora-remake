	}
	function onSliderMoveEnd(target){
		if(_owner !== null && typeof _owner.onSliderMoveEnd != "undefined") _owner.onSliderMoveEnd(target);
	}
	function onEditControlOk(target){
		if(_owner !== null && typeof _owner.onEditControlOk != "undefined") _owner.onEditControlOk(target);
	}
	function onEditControlEnter(target){
		if(_owner !== null && typeof _owner.onEditControlEnter != "undefined") _owner.onEditControlEnter(target);
	}
